# ClickZetta Lakehouse connection
# Copy this file to .env and fill in your values
CLICKZETTA_SERVICE=cn-shanghai-alicloud.api.clickzetta.com
CLICKZETTA_INSTANCE=<your-instance-id>
CLICKZETTA_WORKSPACE=<your-workspace>
CLICKZETTA_USERNAME=<your-username>
CLICKZETTA_PASSWORD=<your-password>
CLICKZETTA_VCLUSTER=default

# Schema and Volume names (can keep defaults)
CLICKZETTA_SCHEMA=frostbyte_raw_pos
CLICKZETTA_VOLUME=frostbyte_vol
# Volume is created in frostbyte_raw_pos schema (created by setup.py via cz-cli)

# cz-cli profile name (used by 08_orchestrate_tasks.sh)
CZ_PROFILE=frostbyte
